JANUS_LOG_LEVEL=INFO
JANUS_SPARK_APP_NAME=janus-local
JANUS_SPARK_MASTER=local[*]
JANUS_SPARK_WAREHOUSE_DIR=data/metadata/spark-warehouse
JANUS_SPARK_IVY_DIR=data/metadata/ivy
JANUS_ICEBERG_CATALOG_NAME=janus
JANUS_ICEBERG_WAREHOUSE_DIR=data/metadata/iceberg
JANUS_ICEBERG_RUNTIME_PACKAGE=org.apache.iceberg:iceberg-spark-runtime-4.0_2.13:1.10.1
JANUS_ICEBERG_DEFAULT_NAMESPACE=bronze
JANUS_DATA_ROOT=data
JANUS_RAW_DIR=data/raw
JANUS_BRONZE_DIR=data/bronze
JANUS_METADATA_DIR=data/metadata
