JANUS_LOG_LEVEL=INFO
JANUS_SPARK_APP_NAME=janus-cluster
JANUS_SPARK_MASTER=spark://spark-master:7077
JANUS_SPARK_WAREHOUSE_DIR=/opt/janus/data/metadata/spark-warehouse
JANUS_SPARK_IVY_DIR=/opt/janus/data/metadata/ivy
JANUS_ICEBERG_CATALOG_NAME=janus
JANUS_ICEBERG_WAREHOUSE_DIR=/opt/janus/data/metadata/iceberg
JANUS_ICEBERG_RUNTIME_PACKAGE=org.apache.iceberg:iceberg-spark-runtime-4.0_2.13:1.10.1
JANUS_ICEBERG_DEFAULT_NAMESPACE=bronze
JANUS_SPARK_SHUFFLE_PARTITIONS=200
JANUS_DATA_ROOT=/opt/janus/data
JANUS_RAW_DIR=/opt/janus/data/raw
JANUS_BRONZE_DIR=/opt/janus/data/bronze
JANUS_METADATA_DIR=/opt/janus/data/metadata
